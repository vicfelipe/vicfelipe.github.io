---
import BaseLayout from '@/layouts/BaseLayout.astro';
import CategoryPill from '@/components/CategoryPill.astro';
import ArticleRow from '@/components/ArticleRow.astro';
import { getCollection } from 'astro:content';
import { useTranslations, type Lang } from '@/i18n/strings';
import { CATEGORIES } from '@/lib/categories';
import { entrySlug } from '@/lib/utils';

export async function getStaticPaths() {
  const langs: Lang[] = ['pt', 'en'];
  const catIds = CATEGORIES.map((c) => c.id);
  return langs.flatMap((lang) =>
    catIds.map((id) => ({ params: { lang, id }, props: { lang, id } }))
  );
}

const { lang, id } = Astro.params as { lang: Lang; id: string };
const t = useTranslations(lang);

const cat = CATEGORIES.find((c) => c.id === id)!;
const collection = lang === 'pt' ? 'pt-articles' : 'en-articles';

const allArticles = await getCollection(collection, (a) => !a.data.draft);
const articles = allArticles
  .filter((a) => a.data.category === id)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const counts = allArticles.reduce<Record<string, number>>((acc, a) => {
  acc[a.data.category] = (acc[a.data.category] ?? 0) + 1;
  return acc;
}, {});
---

<BaseLayout
  title={`${cat[lang]} — ${t('cat_title')} — Victor Alencastro`}
  description={cat.desc[lang]}
  lang={lang}
>
  <div class="page-container">
    <header class="page-header">
      <p class="page-kicker">/ {t('cat_title').toLowerCase()}</p>
      <h1 class="page-title">{cat[lang]}</h1>
      <p class="page-lede">{cat.desc[lang]}</p>
    </header>

    <div class="filter-row">
      <a href={`/${lang}/categories`} class="category-pill">All</a>
      {
        CATEGORIES.map((c) => (
          <CategoryPill
            variant="pill"
            id={c.id}
            label={`${c[lang]} (${counts[c.id] ?? 0})`}
            count={counts[c.id] ?? 0}
            lang={lang}
            active={c.id === id}
          />
        ))
      }
    </div>

    <div class="articles-list">
      {
        articles.length > 0 ? (
          articles.map((article) => (
            <ArticleRow
              title={article.data.title}
              description={article.data.description}
              slug={entrySlug(article.id)}
              lang={lang}
              date={article.data.dateFormatted[lang]}
              readingTime={article.data.readingTime ?? 8}
              tags={article.data.tags}
              category={article.data.category}
              articleLang={article.data.language}
            />
          ))
        ) : (
          <p class="empty">No articles in this category yet.</p>
        )
      }
    </div>
  </div>
</BaseLayout>

<style>
  .page-header {
    margin-bottom: 40px;
  }

  .articles-list {
    border: 1px solid var(--line);
    border-radius: var(--r-lg);
    overflow: hidden;
    background: var(--paper);
  }

  .empty {
    padding: 48px 24px;
    text-align: center;
    color: var(--ink-3);
    font-family: var(--font-mono);
    font-size: 14px;
  }
</style>
