---
import '@/styles/global.css';
import Navbar from '@/components/Navbar.astro';
import Footer from '@/components/Footer.astro';
import { localePath } from '@/lib/utils';

interface Props {
  title: string;
  description?: string;
  lang: 'pt' | 'en';
  ogImage?: string;
  canonicalUrl?: string;
  noIndex?: boolean;
  ogType?: string;
  schemaOrg?: string;
}

const {
  title,
  description,
  lang,
  ogImage,
  canonicalUrl,
  noIndex = false,
  ogType = 'website',
  schemaOrg,
} = Astro.props;

const siteUrl = 'https://victorcode.dev';
const canonical = canonicalUrl ?? new URL(Astro.url.pathname, siteUrl).href;
const ogImageUrl = ogImage ?? `${siteUrl}/og-default.png`;
const canonicalPath = new URL(canonical).pathname;
const strippedPath = canonicalPath.replace(/^\/(pt|en)/, '') || '/';
const ptUrl = new URL(strippedPath, siteUrl).href;
const enUrl = new URL(`/en${strippedPath}`, siteUrl).href;
---

<!doctype html>
<html lang={lang === 'pt' ? 'pt-BR' : 'en'} data-theme="light" data-density="regular">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- SEO -->
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    {noIndex && <meta name="robots" content="noindex" />}

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content={ogType} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content={lang === 'pt' ? 'pt_BR' : 'en_US'} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Hreflang -->
    <link rel="alternate" hreflang="pt-BR" href={ptUrl} />
    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="x-default" href={ptUrl} />

    <!-- RSS -->
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Victor Alencastro"
      href={localePath(lang, '/rss.xml')}
    />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght,SOFT@9..144,500,100&family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,600;1,8..60,400&family=IBM+Plex+Sans:wght@400;500;600&family=JetBrains+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />

    <!-- Schema.org for articles -->
    {schemaOrg && <script type="application/ld+json" set:html={schemaOrg} />}

    <!-- Netlify Identity: handles recovery/invite tokens that land on the main site -->
    <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
    <script is:inline>
      if (window.netlifyIdentity) {
        window.netlifyIdentity.on('init', function (user) {
          if (!user) {
            window.netlifyIdentity.on('login', function () {
              document.location.href = '/admin/';
            });
          }
        });
      }
    </script>

    <!-- Theme & density: inline to avoid flash -->
    <script is:inline>
      (function () {
        var t = localStorage.getItem('theme');
        document.documentElement.setAttribute('data-theme', t || 'light');
        var d = localStorage.getItem('density') || 'regular';
        document.documentElement.setAttribute('data-density', d);
      })();
    </script>
  </head>
  <body>
    <Navbar lang={lang} />
    <main>
      <slot />
    </main>
    <Footer lang={lang} />

    <!-- Enhance all Shiki code blocks with language label and copy button -->
    <script is:inline>
      (function () {
        document.querySelectorAll('pre.astro-code').forEach(function (pre) {
          var lang = pre.getAttribute('data-language') || '';
          var wrapper = document.createElement('div');
          wrapper.className = 'code-wrap';

          var header = document.createElement('div');
          header.className = 'code-hdr';

          if (lang) {
            var badge = document.createElement('span');
            badge.className = 'code-lang-badge';
            badge.textContent = lang;
            header.appendChild(badge);
          }

          var dots = document.createElement('div');
          dots.className = 'code-dots';
          dots.innerHTML = '<span></span><span></span><span></span>';
          header.insertBefore(dots, header.firstChild);

          var copyBtn = document.createElement('button');
          copyBtn.className = 'code-copy-btn';
          copyBtn.textContent = 'Copy';
          copyBtn.setAttribute('aria-label', 'Copy code');
          copyBtn.addEventListener('click', function () {
            var code = pre.querySelector('code');
            navigator.clipboard.writeText(code ? code.textContent || '' : '').then(function () {
              copyBtn.textContent = '✓ Copied';
              setTimeout(function () { copyBtn.textContent = 'Copy'; }, 1500);
            });
          });
          header.appendChild(copyBtn);

          pre.parentNode.insertBefore(wrapper, pre);
          wrapper.appendChild(header);
          wrapper.appendChild(pre);
        });
      })();
    </script>
  </body>
</html>
