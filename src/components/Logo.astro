---
import { localePath } from '@/lib/utils';
interface Props {
  lang: 'pt' | 'en';
}
const { lang } = Astro.props;
---

<a href={localePath(lang, '/')} class="logo" aria-label="Victor Alencastro — Home">
  <span class="logo-mark">
    <span class="logo-bracket">{`{`}</span>
    <span class="logo-dot"></span>
    <span class="logo-bracket">{`}`}</span>
  </span>
  <span class="logo-text">
    <span class="logo-name">victor</span><span class="logo-tld">.alencastro</span>
  </span>
</a>

<style>
  .logo {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: var(--ink);
    font-weight: 600;
    letter-spacing: -0.01em;
  }

  .logo-mark {
    display: inline-flex;
    align-items: center;
    gap: 2px;
    font-family: var(--font-mono);
    font-size: 14px;
    width: 26px;
    height: 26px;
    justify-content: center;
    background: var(--accent-soft);
    border-radius: var(--r-sm);
    color: var(--accent);
  }

  .logo-bracket {
    font-weight: 600;
  }

  .logo-dot {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--accent);
    display: inline-block;
    flex-shrink: 0;
  }

  .logo-text {
    font-family: var(--font-sans);
    font-size: 15px;
    display: inline-flex;
    align-items: baseline;
  }

  .logo-name {
    font-weight: 600;
  }

  .logo-tld {
    color: var(--ink-3);
    font-weight: 500;
  }

  .logo:hover .logo-name {
    color: var(--accent-ink);
  }

  [data-theme="dark"] .logo:hover .logo-name {
    color: var(--accent);
  }
</style>
