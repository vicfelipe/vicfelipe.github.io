---
interface Props {
  id: string;
  label: string;
  count: number;
  lang: 'pt' | 'en';
  variant?: 'pill' | 'card';
  active?: boolean;
}

const { id, label, count, lang, variant = 'pill', active = false } = Astro.props;
const index = ['platform', 'backend', 'databases', 'observability', 'data', 'career'].indexOf(id);
const num = String(index + 1).padStart(2, '0');
---

{
  variant === 'pill' ? (
    <a
      href={`/${lang}/categories/${id}`}
      class:list={['category-pill', { 'category-pill--active': active }]}
    >
      {label}
    </a>
  ) : (
    <a href={`/${lang}/categories/${id}`} class="cat-card">
      <span class="cat-card__arrow" aria-hidden="true">→</span>
      <div class="cat-card-head">
        <span class="cat-card-id">// {num}</span>
        <span class="cat-card-count">{count} art.</span>
      </div>
      <h3 class="cat-card-title">{label}</h3>
    </a>
  )
}

<style>
  .cat-card {
    position: relative;
    padding: 28px;
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: var(--r-lg);
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    gap: 12px;
    transition: background 0.2s, border-color 0.2s;
  }

  .cat-card:hover {
    background: var(--paper-2);
    border-color: var(--ink-4);
  }

  .cat-card-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: var(--font-mono);
    font-size: 12px;
  }

  .cat-card-id {
    color: var(--accent);
    font-weight: 500;
  }

  [data-theme="dark"] .cat-card-id {
    color: var(--accent);
  }

  .cat-card-count {
    color: var(--ink-3);
  }

  .cat-card-title {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: 24px;
    letter-spacing: -0.015em;
    margin: 0;
    color: var(--ink);
  }

  .cat-card__arrow {
    position: absolute;
    top: 24px;
    right: 24px;
    color: var(--ink-4);
    font-size: 14px;
    transition: color 0.2s, transform 0.2s;
  }

  .cat-card:hover .cat-card__arrow {
    color: var(--accent);
    transform: translate(3px, -3px);
  }
</style>
